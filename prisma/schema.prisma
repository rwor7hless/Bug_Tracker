generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id          String   @id @default(uuid())
  title          String?
  description    String
  crashReport    String?
  resolveComment String?
  status      Status   @default(OPEN)
  category    Category @default(OTHER)
  urgency     Urgency  @default(NORMAL)
  duplicateOf String?
  bumpCount   Int      @default(1)
  reportedBy  String
  telegramId  String?
  tag         String?  @unique
  tagNumber   Int?
  embedding   Unsupported("vector(384)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photosDeleted Boolean @default(false)
  photos      TicketPhoto[]
  comments    TicketComment[]
}

model TicketPhoto {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  filename  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

enum Status {
  OPEN
  IN_PROGRESS
  DUPLICATE
  RESOLVED
}

enum Category {
  CRASH
  LAG
  VISUAL
  GAMEPLAY
  OTHER
  SUGGESTION
}

enum Urgency {
  NORMAL
  HIGH
  CRITICAL
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(MODERATOR)
  telegramId   String?
  createdAt    DateTime @default(now())
  comments     TicketComment[]
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  MODERATOR
}

model Moderator {
  id         String   @id @default(uuid())
  telegramId String   @unique
  name       String?
  createdAt  DateTime @default(now())
}
